SERVER_TYPE=http
SERVER_PORT=8080
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=your_secure_api_key
LOG_LEVEL=ERROR
# Required comma-separated lists (avoid undefined .split)
CORS_ORIGIN=*
CORS_METHODS=POST,GET,PUT,DELETE
# Enable database usage (required for instance creation)
STORE_MESSAGES=true
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:postgres@db:5432/evolution
DATABASE_CONNECTION_URI=postgresql://postgres:postgres@db:5432/postgres
# --- S3 Storage (For Media files - Optional) ---
S3_ENABLED=false
